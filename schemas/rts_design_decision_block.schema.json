{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RTS Design Decision Block",
  "type": "object",
  "required": [
    "id",
    "type",
    "project",
    "screen",
    "created_at",
    "context",
    "research",
    "findings",
    "decision",
    "constraints",
    "assumptions",
    "action",
    "outcome"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "type": {"const": "design_decision"},
    "project": {"type": "string", "minLength": 1},
    "screen": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "context": {"type": "string", "minLength": 1},
    "research": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/source"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "object",
      "required": ["observed_patterns", "anti_patterns"],
      "properties": {
        "observed_patterns": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "anti_patterns": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["selected_pattern", "rationale"],
      "properties": {
        "selected_pattern": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "constraints": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "action": {
      "type": "object",
      "required": ["outputs"],
      "properties": {
        "outputs": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "outcome": {
      "type": "object",
      "required": ["status", "expected", "observed"],
      "properties": {
        "status": {"enum": ["proposed", "in_progress", "validated", "rejected"]},
        "expected": {"type": "array", "items": {"type": "string"}},
        "observed": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "source_id",
        "source_type",
        "provider",
        "query",
        "retrieved_at",
        "reference_url",
        "screenshot_path",
        "license_or_usage_note",
        "confidence",
        "notes"
      ],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "source_type": {"enum": ["screenshot", "article", "product-page", "design-system"]},
        "provider": {"type": "string", "minLength": 1},
        "query": {"type": "string"},
        "retrieved_at": {"type": "string", "format": "date-time"},
        "reference_url": {"type": "string"},
        "screenshot_path": {"type": "string"},
        "license_or_usage_note": {"type": "string"},
        "confidence": {"enum": ["low", "medium", "high"]},
        "notes": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "id": "decision-rts-audit-console-dashboard-001",
      "type": "design_decision",
      "project": "RTS",
      "screen": "audit_console_dashboard",
      "created_at": "2026-05-05T00:00:00Z",
      "context": "Audit reviewers need to reconstruct decision history quickly without navigating across multiple views.",
      "research": {
        "sources": [
          {
            "source_id": "src-dashboard-patterns-001",
            "source_type": "article",
            "provider": "lazyweb",
            "query": "developer dashboard traceability patterns",
            "retrieved_at": "2026-05-05T00:00:00Z",
            "reference_url": "na",
            "screenshot_path": "na",
            "license_or_usage_note": "Example placeholder; replace with source-specific usage notes.",
            "confidence": "medium",
            "notes": "Placeholder provenance for example contract validation."
          }
        ]
      },
      "findings": {
        "observed_patterns": ["Three-pane layouts improve traceability review throughput."],
        "anti_patterns": ["Hidden provenance links slow evidence review."]
      },
      "decision": {
        "selected_pattern": "Three-pane operational console",
        "rationale": "Persistent navigation, timeline, and inspector regions keep source evidence visible while decisions are reviewed."
      },
      "constraints": ["Expose context, assumptions, constraints, action, and outcome."],
      "assumptions": ["Primary users are technical reviewers."],
      "action": {
        "outputs": [
          "report.md",
          "ui-spec.md",
          "implementation-brief.md",
          "rts-design-decision-block.yaml"
        ]
      },
      "outcome": {"status": "proposed", "expected": ["Faster audits."], "observed": []}
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rts.local/schemas/rts_design_decision_block.schema.json",
  "title": "RTS Design Decision Block",
  "type": "object",
  "required": ["id", "type", "project", "screen", "created_at", "context", "research", "findings", "decision", "constraints", "assumptions", "action", "outcome"],
  "properties": {
    "id": { "type": "string" },
    "type": { "const": "design_decision" },
    "project": { "type": "string" },
    "screen": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "context": { "type": "string" },
    "research": {
      "type": "object",
      "required": ["sources"],
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source_id", "source_type", "provider", "query", "retrieved_at", "confidence"],
            "properties": {
              "source_id": { "type": "string" },
              "source_type": { "type": "string" },
              "provider": { "type": "string" },
              "query": { "type": "string" },
              "retrieved_at": { "type": "string", "format": "date-time" },
              "reference_url": { "type": "string" },
              "screenshot_path": { "type": "string" },
              "license_or_usage_note": { "type": "string" },
              "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
              "notes": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "findings": {
      "type": "object",
      "required": ["observed_patterns", "anti_patterns"],
      "properties": {
        "observed_patterns": { "type": "array", "items": { "type": "string" } },
        "anti_patterns": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "decision": {
      "type": "object",
      "required": ["selected_pattern", "rationale"],
      "properties": {
        "selected_pattern": { "type": "string" },
        "rationale": { "type": "string" }
      },
      "additionalProperties": true
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "action": {
      "type": "object",
      "required": ["outputs"],
      "properties": {
        "outputs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "outcome": {
      "type": "object",
      "required": ["status", "expected", "observed"],
      "properties": {
        "status": { "type": "string", "enum": ["proposed", "in_progress", "validated", "rejected"] },
        "expected": { "type": "array", "items": { "type": "string" } },
        "observed": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ui_improvement_audit inputs",
  "type": "object",
  "required": [
    "project",
    "screen",
    "current_ui_snapshot",
    "target_outcomes"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "screen": {
      "type": "string"
    },
    "current_ui_snapshot": {
      "type": "string"
    },
    "target_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "reference_queries": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
